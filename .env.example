# 기존 로컬 도커 컨테이너 접속 정보 (git/Docker/docker-compose.yml 기준)
# 실제 값은 .env 로 복사해 사용 (.env 는 커밋 금지)

APP_NAME=chatbot-backend
ENV=local
API_PREFIX=/v1

# 관리자 API 토큰 (§03 §1.2). 비어 있으면 관리자 API 비활성(401).
ADMIN_TOKEN=

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# LLM (Claude)
# LLM_PROVIDER: anthropic(API 키 사용) | claude_cli(로컬 Claude Code CLI, 키 불필요)
LLM_PROVIDER=anthropic
# claude_cli 사용 시 CLI 경로(기본 PATH 의 claude)
# CLAUDE_CLI_PATH=claude
ANTHROPIC_API_KEY=
# 라우팅: rule(규칙, LLM 0, 기본·빠름) | llm(Haiku 분류) | hybrid(규칙→모호시 LLM)
ROUTE_MODE=rule
# 검증(verify) 노드: 선택. true 면 답변 근거 충실성 점검(경량 판사 — 오기각 주의)
VERIFY_ENABLED=false
LLM_MODEL_LIGHT=claude-haiku-4-5-20251001
LLM_MODEL_MAIN=claude-sonnet-4-6
LLM_MODEL_HEAVY=claude-opus-4-8
LLM_TIMEOUT_SECONDS=60

# ── 임베딩 ──────────────────────────────────────────
# hash(결정적, 키 불필요, 기본) | fastembed(로컬 ONNX 실제 모델, 키 불필요)
# ⚠️ 벤더 서버(faq/general)와 backend/model/dim 을 반드시 동일하게(§08 §9.3)
EMBEDDING_BACKEND=hash
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# ── 검색/RAG 튜닝 ───────────────────────────────────
DOC_TOP_K=20
DOC_TOP_N=5
TOOL_TOP_K=5
FAQ_SEARCH_TOP_K=5
# 무관 FAQ 제외 임계값 — EMBEDDING_BACKEND 과 짝(모델마다 분포 다름)
FAQ_SCORE_FLOOR=0.3
MAX_TOOL_ITERS=3

# ── MCP 외부 서버 호출 타임아웃(초) ─────────────────
MCP_CALL_TIMEOUT_SECONDS=10.0
FAQ_CALL_TIMEOUT_SECONDS=5.0
