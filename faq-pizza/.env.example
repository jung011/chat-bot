# 피자집 FAQ MCP 서버 설정 (독립 배포)
COMPANY_ID=pizza
FAQ_COLLECTION=faq_pizza
FAQ_THRESHOLD=0.85
EMBEDDING_DIM=384

# 공유 Qdrant (기존 로컬 도커 컨테이너)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# 서버 바인딩
HOST=127.0.0.1
PORT=9001

# 임베딩 백엔드 — ⚠️ 오케스트레이터/타 서버와 동일해야 함(§08 §9.3)
# hash(기본) | fastembed(로컬 ONNX 실제 모델). 적재=검색 동일 임베더 필수.
EMBEDDING_BACKEND=hash
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
