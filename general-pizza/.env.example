# 피자집 일반(도메인) MCP 서버 설정 (독립 배포)
COMPANY_ID=pizza
DOCUMENTS_COLLECTION=documents
EMBEDDING_DIM=384
DOC_TOP_K=20
DOC_TOP_N=5

# 공유 Qdrant (기존 로컬 도커 컨테이너)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# 서버 바인딩
HOST=127.0.0.1
PORT=9101

# 임베딩 백엔드 — ⚠️ 오케스트레이터와 반드시 동일(공유 documents 컬렉션, §08 §9.3)
# hash(기본) | fastembed(로컬 ONNX 실제 모델).
EMBEDDING_BACKEND=hash
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
